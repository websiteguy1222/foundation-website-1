---
import RegisterButton from './RegisterButton.astro';
---
<section class="section camp">
  <div class="sec-inner">
    <div class="camp-inner">
      <div class="camp-visual">
        <div class="camp-big">5</div>
        <div class="camp-unit">Days of training</div>
        <div class="camp-sub">☀️ Summer ice camp at the Pettit</div>
      </div>
      <div>
        <div class="label">
          <span class="label-dot" aria-hidden="true"></span>
          Annual event
        </div>
        <h2 class="heading">Summer <em>ice camp</em></h2>
        <p class="body-text">
          Five days of focused speed skating training at the Pettit National
          Ice Center. Three hours on ice per day plus dryland conditioning —
          all designed to improve technique and build real speed.
        </p>
        <div class="camp-details">
          <div class="camp-row">
            <span class="camp-row-icon" aria-hidden="true">📍</span>
            <div>
              <div class="camp-row-lbl">Location</div>
              <div class="camp-row-val">Pettit National Ice Center</div>
            </div>
          </div>
          <div class="camp-row">
            <span class="camp-row-icon" aria-hidden="true">🕐</span>
            <div>
              <div class="camp-row-lbl">On-ice hours</div>
              <div class="camp-row-val">3 hours per day of technical training</div>
            </div>
          </div>
          <div class="camp-row">
            <span class="camp-row-icon" aria-hidden="true">🏃</span>
            <div>
              <div class="camp-row-lbl">Training types</div>
              <div class="camp-row-val">On-ice technique + dryland conditioning</div>
            </div>
          </div>
        </div>
        <div style="margin-top:1.5rem">
          <RegisterButton label="Register at Elmbrook Speedskating →" />
        </div>
      </div>
    </div>
  </div>
</section>
