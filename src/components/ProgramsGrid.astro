---
import RegisterButton from './RegisterButton.astro';
---
<section class="section programs">
  <div class="sec-inner">
    <h2 class="heading">Skate for All. <em>Inspire for Life.</em></h2>
    <div class="prog-grid">
      <article class="prog-card">
        <h3 class="prog-title">Training &amp; Free Tryout</h3>
        <ul class="prog-list">
          <li>No prior speedskating experience required</li>
          <li>Open to all students ages 4–18</li>
          <li>Speedskate rental provided</li>
          <li>Led by US Speedskating Certified Coaches</li>
          <li>Managed by Elmbrook Speedskating Club | Let's Skate Foundation</li>
        </ul>
        <RegisterButton label="Register" href="https://www.speedskatingevents.org/2026letsskate" />
      </article>

      <article class="prog-card">
        <h3 class="prog-title">Community Events</h3>
        <ul class="prog-list">
          <li>Let's Skate Day</li>
          <li>Annual Interscholastic Speed Skating Challenge</li>
          <li>School District Speedskating Integration Events</li>
          <li>Seminars &amp; Educational Workshops</li>
        </ul>
        <RegisterButton label="More Information" href="/programs" />
      </article>

      <article class="prog-card">
        <h3 class="prog-title">Outreach Programs</h3>
        <ul class="prog-list">
          <li>Let's Skate Ambassador Program</li>
          <li>Let's Skate Coach Mentorship Program</li>
          <li>Let's Skate AI Lab</li>
        </ul>
        <RegisterButton label="Learn More" href="/programs" />
      </article>
    </div>
  </div>
</section>

<style>
  .heading {
    font-size: clamp(2.4rem, 4vw, 3.4rem);
    margin-bottom: 0.75rem;
  }
  .prog-card {
    display: flex;
    flex-direction: column;
  }
  .prog-list {
    list-style: disc;
    padding-left: 1.2rem;
    font-size: 0.9rem;
    color: var(--mid);
    line-height: 1.9;
    margin: 1.4rem 0 1.4rem;
    flex: 1;
  }
</style>
