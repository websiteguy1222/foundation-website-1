<section class="section mission">
  <div class="sec-inner">
    <div class="mission-grid">
      <div class="mission-text">
        <div class="label">
          <span class="label-dot" aria-hidden="true"></span>
          Our mission
        </div>
        <h2 class="heading">
          Bringing speed&shy;skating to <em>every kid</em> in our community
        </h2>
        <p>
          We're the first and only school-district speed skating club in the nation —
          teaching 300+ kids to skate and sending 10 to national competition.
          Accessible, affordable, and joyful for every skater.
        </p>
        <div class="mission-chips">
          <span class="chip chip-green">Summer camp</span>
          <span class="chip chip-green">All ages</span>
          <span class="chip chip-pink">Try 2 practices free</span>
          <span class="chip chip-gray">Equipment rentals</span>
        </div>
      </div>
      <div class="mission-card">
        <p class="mission-card-quote">
          We started with a handful of kids and a dream. Now we're bringing
          speed skating to every child in our community — and we couldn't be prouder.
        </p>
        <p class="mission-card-attr">— Let's Skate Foundation</p>
        <div class="mission-card-tags">
          <span class="mini-chip">Elmbrook School District</span>
          <span class="mini-chip">Pettit National Ice Center</span>
          <span class="mini-chip">Wisconsin speed skating</span>
        </div>
      </div>
    </div>
  </div>
</section>
