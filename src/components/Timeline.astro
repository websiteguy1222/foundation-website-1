---
const years = [
  {
    year: "2026",
    events: [
      { date: "May 2026", caption: "Let's Skate Foundation was honored to be invited to participate in the Burleigh High Interest Day event at Burleigh Elementary School in Elmbrook School District." },
      { date: "May 2026", caption: "Let's Skate Foundation launched the Let's Skate Ambassador Program and Let's Skate AI Lab under its Outreach Programs. These programs aim to promote speedskating development in multi-dimensional aspects and cultivate well-rounded speed skaters." },
      { date: "April 2026", caption: "Let's Skate Foundation hosted the 2026 Spring Let's Skate Day - Post-Olympic Edition, where 50 skaters had the opportunity to skate with two-time Olympian Ethan Cepuran." },
      { date: "March 2026", caption: "Jeremy Dong, the first skater from the Elmbrook Speedskating Club to qualify for the USS Short Track Age Group Nationals, was invited to the Elmbrook School District’s 11th “Engaged in Excellence” event in recognition of his national milestone in speedskating and his representation of the club." },
      { date: "March 2026", caption: "Let's Skate Foundation co-organized the Tour of Olympian event, bringing inspiration and passion for sports to local students. Students interacted with 2026 speedskating Olympians Julie Letai, Ethan Cepuran, and Sarah Warren." },
      { date: "March 2026", caption: "Let's Skate Foundation was invited by Brookfield Elementary School to deliver speedskating basic training in PE classes, providing students with hands-on sports experience." },
      { date: "February 2026", caption: "Let's Skate Foundation participated in the Explore STEAM Event hosted by the Elmbrook Education Foundation." },
    ],
  },
  {
    year: "2025",
    events: [
      { date: "September 2025", caption: "Let's Skate Foundation launched the seasonal \"Let's Skate Day\" events to provide the community with more public speedskating experience opportunities. The first event kicked off at Hartmeyer Ice Arena, helping promote speedskating in Madison, Wisconsin." },
      { date: "August 2025", caption: "Hosted the annual Elmbrook Speedskating Summer Camp." },
      { date: "June 2025", caption: "Let's Skate Foundation hosted the Interscholastic Speedskating Challenge, reviving school-based speedskating in the local community for the first time since the 1980s." },
      { date: "February 2025", caption: "Elmbrook speed skaters represented the local school district to welcome Team USA and global speedskating fans to the ISU Speedskating World Cup held at the Pettit National Ice Center." },
    ],
  },
  {
    year: "2024",
    events: [
      { date: "September - December 2024", caption: "Elmbrook Speedskating Club participated in three regional speedskating competitions." },
      { date: "August 2024", image: "/Elmbrook Speedskating Club 2024 Summer.jpeg", alt: "Elmbrook 2024 Summer Camp", caption: "Hosted annual Elmbrook Speedskating Summer Camp." },
      { date: "July 2024", caption: "Let's Skate Foundation was officially founded, built upon the successful operational model of the school speedskating club to expand its reach and influence nationwide. The foundation manages Elmbrook Speedskating Club as its core training program." },
      { date: "July 2024", caption: "Let's Skate Foundation launched the Coach Mentorship Program. The initiative aims to expand the national youth speedskating coaching talent pool and provide valuable community service opportunities for emerging volunteer coaches." },
      { date: "April - July 2024", caption: "Provided consistent spring and summer speedskating training for the local community." },
      { date: "April 2024", image: "/Elmbrook Speedskating Club 2024 China Trip.jpg", alt: "Elmbrook Alumni in China", caption: "Elmbrook alumni participated in the Sino-US Speedskating Invitational Tournament in Tangshan, China." },
      { date: "March 2024", caption: "Multiple Elmbrook alumni competed at the 2024 US Short Track Speedskating Age Group National Championships." },
      { date: "February 2024", caption: "Elmbrook speed skaters made their debut at the 2024 US Long Track Speedskating Age Group National Championships." },
    ],
  },
  {
    year: "2023",
    events: [
      { date: "December 2023", caption: "Launched the Free Tryout Program, offering more than ten free public speedskating trial sessions annually." },
      { date: "September - November 2023", caption: "Elmbrook Speedskating Club participated in two regional speedskating competitions." },
      { date: "March - August 2023", caption: "Continued to expand and enrich the local youth speedskating community." },
    ],
  },
  {
    year: "2022",
    events: [
      { date: "July - November 2022", caption: "Elmbrook Speedskating Club participated in three regional speedskating competitions." },
      { date: "August 2022", caption: "Aaron Liu, founder of Elmbrook Speedskating Club, presented the innovative school-district-based speedskating model at the US Speedskating Membership Forum." },
      { date: "June 2022", caption: "Hosted the first Elmbrook Speedskating Summer Camp." },
    ],
  },
  {
    year: "2021",
    events: [
      { date: "July 2021 - March 2022", caption: "Elmbrook Speedskating Club participated in two regional speedskating competitions." },
      { date: "May 2021", image: "/Elmbrook Speedskating Club Bonnie Blair Guest Appearance.jpg", alt: "Bonnie Blair Guest Appearance", caption: "Welcomed five-time Olympic medalist Bonnie Blair as a guest speaker, who presented the Dedication to Sport Award to team members." },
      { date: "April 2021", caption: "Held the first official speedskating training session of the Elmbrook Speedskating Club." },
      { date: "March 2021", caption: "Hosted the first informational recruitment session at Brookfield Central High School." },
    ],
  },
  {
    year: "2020",
    events: [
      { date: "August 2020", image: "/Elmbrook Speedskating Club First Meeting.jpg", alt: "First Meeting", caption: "Elmbrook Speedskating Club was founded during the COVID-19 pandemic, recognized as the nation's only school-district-based speedskating club." },
    ],
  },
];
---

<div class="tl-wrap">
  <div class="tl-line"></div>

  {years.map(({ year, events }) => (
    <details class="tl-year" open>
      <summary class="tl-year-banner">
        <div class="tl-year-badge">
          <span class="tl-arrow" aria-hidden="true">▶</span>
          {year}
        </div>
      </summary>

      <div class="tl-events">
        {events.map(({ date, image, alt, caption }, i) => (
          <figure class={`tl-row ${i % 2 === 0 ? 'tl-left' : 'tl-right'}`}>

            {image ? (
              <div class="tl-card tl-card-img">
                <img src={image} alt={alt} class="tl-img" loading="lazy" />
                <div class="tl-text">
                  <div class="tl-date">{date}</div>
                  <figcaption class="tl-caption">{caption}</figcaption>
                </div>
              </div>
            ) : (
              <div class="tl-card">
                <div class="tl-date">{date}</div>
                <figcaption class="tl-caption">{caption}</figcaption>
              </div>
            )}

            <span class="tl-dot" aria-hidden="true"></span>
            <div class="tl-spacer" aria-hidden="true"></div>
          </figure>
        ))}
      </div>
    </details>
  ))}
</div>

<style>
  .tl-wrap {
    position: relative;
    max-width: 900px;
    margin: 2rem auto 0;
  }

  /* Vertical line */
  .tl-line {
    position: absolute;
    top: 0; bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 3px;
    background: var(--teal);
    z-index: 0;
  }

  /* Year section */
  .tl-year { position: relative; }

  .tl-year-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
    padding: 1.5rem 0 0.5rem;
    cursor: pointer;
    list-style: none;
  }
  .tl-year-banner::-webkit-details-marker { display: none; }

  .tl-year-badge {
    background: var(--teal);
    color: var(--white);
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 700;
    padding: 0.3rem 1.4rem;
    border-radius: 20px;
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    box-shadow: 0 2px 10px rgba(45, 152, 147, 0.3);
  }

  .tl-arrow {
    font-size: 0.75rem;
    display: inline-block;
    transition: transform 0.2s;
  }
  details[open] .tl-arrow {
    transform: rotate(90deg);
  }

  /* Event rows */
  .tl-row {
    display: flex;
    align-items: flex-start;
    position: relative;
    padding: 0.5rem 0;
  }
  .tl-left  { flex-direction: row; }
  .tl-right { flex-direction: row-reverse; }

  /* Card */
  .tl-card {
    width: calc(50% - 24px);
    padding: 0.9rem 1rem;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: 0 1px 5px rgba(0, 0, 0, 0.06);
    position: relative;
  }
  .tl-left  .tl-card { margin-right: 24px; }
  .tl-right .tl-card { margin-left: 24px; }

  /* Connector line from card edge to dot */
  .tl-left .tl-card::after {
    content: '';
    position: absolute;
    right: -24px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 2px;
    background: var(--border);
  }
  .tl-right .tl-card::after {
    content: '';
    position: absolute;
    left: -24px;
    top: 50%;
    transform: translateY(-50%);
    width: 24px;
    height: 2px;
    background: var(--border);
  }

  /* Image card variant */
  .tl-card-img {
    padding: 0;
    display: flex;
    flex-direction: row;
  }
  .tl-card-img .tl-img {
    width: 44%;
    flex-shrink: 0;
    object-fit: cover;
    align-self: stretch;
    border-radius: var(--radius-md) 0 0 var(--radius-md);
  }
  .tl-text {
    flex: 1;
    padding: 0.9rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .tl-date {
    font-size: 0.78rem;
    font-weight: 800;
    color: var(--teal);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.35rem;
  }
  .tl-caption {
    font-size: 0.88rem;
    color: var(--mid);
    line-height: 1.65;
  }

  /* Dot on the center line */
  .tl-dot {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 14px;
    height: 14px;
    background: var(--teal);
    border-radius: 50%;
    border: 3px solid var(--white);
    box-shadow: 0 0 0 2px var(--teal);
    z-index: 2;
  }

  /* Empty spacer fills the opposite half */
  .tl-spacer { width: calc(50% + 24px); }

  /* Mobile — single column, line on left */
  @media (max-width: 620px) {
    .tl-line { left: 20px; transform: none; }

    .tl-year-banner { justify-content: flex-start; padding-left: 3rem; }
    .tl-year-badge  { font-size: 1.05rem; }

    .tl-row { flex-direction: column !important; padding-left: 3rem; }
    .tl-spacer { display: none; }
    .tl-card  { width: 100%; margin: 0 !important; }
    .tl-card::after { display: none; }

    .tl-dot { left: 20px; top: 1.4rem; }

    .tl-card-img { flex-direction: column; }
    .tl-card-img .tl-img { width: 100%; height: 160px; align-self: auto; }
  }
</style>
