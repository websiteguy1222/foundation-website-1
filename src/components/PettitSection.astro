---
import RegisterButton from './RegisterButton.astro';
---
<section class="section pettit">
  <div class="sec-inner">
    <div class="pettit-inner">
      <div>
        <div class="label">
          <span class="label-dot" aria-hidden="true"></span>
          Home ice
        </div>
        <h2 class="heading">
          We train at the <em>Pettit National Ice Center</em>
        </h2>
        <p class="body-text">
          One of America's premier speed skating venues — right here in
          Milwaukee, Wisconsin. Wisconsin has had a representative on every
          U.S. Winter Olympic speed skating team since 1932. That's the
          legacy we skate on.
        </p>
        <RegisterButton label="Register at Elmbrook Speedskating →" />
      </div>
      <div class="pettit-cards">
        <div class="pettit-card">
          <div class="pettit-card-icon" aria-hidden="true">📍</div>
          <div>
            <div class="pettit-card-lbl">Location</div>
            <div class="pettit-card-val">Pettit National Ice Center, Milwaukee, WI</div>
          </div>
        </div>
        <div class="pettit-card">
          <div class="pettit-card-icon" aria-hidden="true">📧</div>
          <div>
            <div class="pettit-card-lbl">Contact us</div>
            <div class="pettit-card-val">
              <a href="mailto:admin@letsskate.org">admin@letsskate.org</a>
            </div>
          </div>
        </div>
        <div class="pettit-card">
          <div class="pettit-card-icon" aria-hidden="true">⛸</div>
          <div>
            <div class="pettit-card-lbl">Tracks</div>
            <div class="pettit-card-val">Short track (111m) &amp; long track (400m)</div>
          </div>
        </div>
        <div class="pettit-card">
          <div class="pettit-card-icon" aria-hidden="true">⛑</div>
          <div>
            <div class="pettit-card-lbl">Safety</div>
            <div class="pettit-card-val">
              Helmets required for all short track skaters and all long
              track skaters under 18.
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
