---
const values = [
  { img: '/teamwork-2.png', label: 'Community Building' },
  { img: '/teamwork.png', label: 'Inclusion' },
  { img: '/happiness.png', label: 'Fun' },
  { img: '/team.png', label: 'Sportsmanship' },
  { img: '/Olympic_rings_without_rims.svg.png', label: 'Continuing the Olympic Legacy' },
];
---
<section class="values-strip">
  <div class="values-inner">
    {values.map(v => (
      <div class="value-item">
        <img src={v.img} alt={v.label} class="value-icon" />
        <span class="value-label">{v.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .values-strip {
    background: var(--white);
    padding: 3rem 2.5rem;
    border-top: 2px solid var(--border);
    border-bottom: 2px solid var(--border);
  }
  .values-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-around;
    align-items: center;
    flex-wrap: wrap;
    gap: 2rem;
  }
  .value-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    text-align: center;
    max-width: 140px;
  }
  .value-icon {
    width: 80px;
    height: 80px;
    object-fit: contain;
  }
  .value-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--mid);
    line-height: 1.35;
  }
</style>
