---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProgramsGrid from '../components/ProgramsGrid.astro';
import PettitSection from '../components/PettitSection.astro';
import SummerCampSection from '../components/SummerCampSection.astro';
---
<BaseLayout title="Programs" description="Summer ice camp, year-round club, free trial — programs from Elmbrook Speedskating, run by Let's Skate Foundation.">
  <section class="section">
    <div class="sec-inner page-hero">
      <div class="label"><span class="label-dot" aria-hidden="true"></span> What we offer</div>
      <h1 class="heading">Programs for every skater</h1>
      <p class="body-text page-lede">
        From a first-time free trial to national-level competition,
        Elmbrook Speedskating has a place for every kid on the ice.
      </p>
    </div>
  </section>
  <ProgramsGrid />
  <PettitSection />
  <SummerCampSection />
</BaseLayout>

<style>
  .page-hero { text-align: center; padding-bottom: 1rem; }
  .page-hero .label { justify-content: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
  .page-lede { max-width: 640px; margin: 1rem auto 0; font-size: 1.05rem; }
</style>
