---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
---
<BaseLayout
  title="About"
  description="Let's Skate Foundation is the 501(c)(3) nonprofit that runs Elmbrook Speedskating, the nation's first school-district speed skating club."
>
  <section class="section">
    <div class="sec-inner page-hero">
      <div class="label"><span class="label-dot" aria-hidden="true"></span> Our story</div>
      <h1 class="heading">The Journey of Let's Skate</h1>
    </div>
    <div class="sec-inner">
      <Timeline />
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { text-align: center; padding-bottom: 1rem; }
  .page-hero .label { justify-content: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
</style>
