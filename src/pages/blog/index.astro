---
import BaseLayout from '../../layouts/BaseLayout.astro';

const press = [
  {
    title: "Brookfield teen's speed skating foundation finalist in statewide competition",
    date: "March 14, 2025",
    source: "FOX6 Milwaukee",
    summary: "Aidan Liu, a three-time national age-group champion and member of the 2025 U.S. Junior World Championships team, was named a finalist in Junior Achievement's Young Entrepreneur competition for his work founding Let's Skate Foundation.",
    url: "https://www.fox6now.com/news/brookfield-teens-speed-skating-foundation-finalist-in-statewide-competition",
  },
  {
    title: "Elmbrook Education Foundation receives $2K donation from Let's Skate Foundation",
    date: "2024",
    source: "GMToday / The Freeman",
    summary: "Let's Skate Foundation donated $2,000 to the Elmbrook Education Foundation, supporting the school district community that made the club possible.",
    url: "https://www.gmtoday.com/the_freeman/news/elmbrook-education-foundation-receives-2k-donation-from-let-s-skate-foundation/article_fb5888db-baf7-5463-ac05-08eb16fcb76c.html",
  },
  {
    title: "BC Student Named to Junior National Speedskating Team",
    date: "2025",
    source: "Elmbrook Schools",
    summary: "Brookfield Central student Aidan Liu was named to the U.S. Junior National Speedskating Team, representing Wisconsin and the Elmbrook community on the national stage.",
    url: "https://www.elmbrookschools.org/news-details/~board/district-news/post/bc-student-named-to-junior-national-speedskating-team",
  },
];
---
<BaseLayout title="News" description="Updates, stories, and announcements from Let's Skate Foundation and Elmbrook Speedskating.">
  <section class="section">
    <div class="sec-inner page-hero">
      <h1 class="heading">News</h1>
      <p class="body-text page-lede">
        Updates, stories, and announcements from the foundation and the club.
      </p>
    </div>

    <div class="sec-inner press-grid">
      {press.map((item) => (
        <a class="press-card" href={item.url} target="_blank" rel="noopener">
          <div class="press-meta">
            <span class="press-source">{item.source}</span>
            <span class="press-date">{item.date}</span>
          </div>
          <h2 class="press-title">{item.title}</h2>
          <p class="press-summary">{item.summary}</p>
          <span class="press-link">Read article →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { text-align: center; }
  .page-hero .label { justify-content: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
  .page-lede { max-width: 640px; margin: 1rem auto 0; font-size: 1rem; }

  .press-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .press-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .press-card:hover {
    transform: translateY(-4px);
    border-color: var(--teal);
    box-shadow: 0 16px 40px rgba(0,119,139,0.08);
  }
  .press-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .press-source { color: var(--teal); }
  .press-date { color: var(--mid); }
  .press-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--dark);
    line-height: 1.4;
  }
  .press-summary {
    font-size: 0.87rem;
    color: var(--mid);
    line-height: 1.7;
    flex: 1;
  }
  .press-link {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--teal);
    margin-top: 0.25rem;
  }

  @media (max-width: 880px) { .press-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .press-grid { grid-template-columns: 1fr; } }
</style>
