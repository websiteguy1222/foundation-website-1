---
import BaseLayout from '../layouts/BaseLayout.astro';

// Placeholder gallery — replace src URLs with real photos from Cloudinary
// or your hosting once you have them. Keep alt text descriptive.
const placeholders = Array.from({ length: 9 }, (_, i) => ({
  alt: `Skating photo placeholder ${i + 1}`,
}));
---
<BaseLayout title="Gallery" description="Photos and video from Elmbrook Speedskating practices, meets, and summer camp.">
  <section class="section">
    <div class="sec-inner page-hero">
      <div class="label"><span class="label-dot" aria-hidden="true"></span> Moments on ice</div>
      <h1 class="heading">Gallery</h1>
      <p class="body-text page-lede">
        Photos and video from practices, meets, and summer camp. Replace
        these placeholders with real images once you have them — the grid
        will adapt automatically.
      </p>
    </div>

    <div class="sec-inner">
      <div class="gallery-grid">
        {placeholders.map((p) => (
          <div class="gallery-tile" role="img" aria-label={p.alt}>
            <span aria-hidden="true">⛸</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { text-align: center; }
  .page-hero .label { justify-content: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
  .page-lede { max-width: 640px; margin: 1rem auto 0; font-size: 1rem; }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-top: 2rem;
  }
  .gallery-tile {
    aspect-ratio: 4 / 3;
    background: var(--teal-lt);
    border-radius: var(--radius-lg);
    display: flex; align-items: center; justify-content: center;
    font-size: 3rem;
    color: var(--teal);
  }
  @media (max-width: 720px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; } }
</style>
