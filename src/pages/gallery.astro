---
<BaseLayout title="Gallery" description="Photos from Let's Skate Foundation events including Let's Skate Day, Tour of Olympians, summer camps, and more.">
  <section class="section">
    <div class="sec-inner page-hero">
      <h1 class="heading">Gallery</h1>
      <p class="body-text page-lede">
        Photos from our events, programs, and community moments.
      </p>
    </div>

    {sections.map((section) => (
      <div class="sec-inner event-section">
        <h2 class="event-title">{section.title}</h2>
        <div class="gallery-grid" style={{ gridTemplateColumns: `repeat(${section.numRows || 4}, 1fr)` }}>
          {section.photos.map((photo) =>
            photo.src
              ? <button type="button" class="gallery-tile-btn" data-full={photo.src} aria-label={`View larger: ${photo.alt}`}><img src={photo.src} alt={photo.alt} class="gallery-tile" loading="lazy" /></button>
              : <div class="gallery-tile gallery-placeholder" role="img" aria-label={photo.alt}><span aria-hidden="true">⛸</span></div>
          )}
        </div>
      </div>
    ))}
  </section>

  <div class="lightbox" id="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <button type="button" class="lightbox-close" aria-label="Close">&times;</button>
    <img class="lightbox-img" id="lightbox-img" src="" alt="" />
  </div>
</BaseLayout>

<script>
  const lightbox = document.getElementById('lightbox') as HTMLElement;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const closeBtn = lightbox?.querySelector('.lightbox-close') as HTMLButtonElement;

  function openLightbox(src: string, alt: string) {
    lightboxImg.src = src;
    lightboxImg.alt = alt;
    lightbox.classList.add('lightbox-open');
    lightbox.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
    closeBtn?.focus();
  }

  function closeLightbox() {
    lightbox.classList.remove('lightbox-open');
    lightbox.setAttribute('aria-hidden', 'true');
    lightboxImg.src = '';
    document.body.style.overflow = '';
  }

  document.querySelectorAll<HTMLButtonElement>('.gallery-tile-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const full = btn.dataset.full;
      const img = btn.querySelector('img');
      if (full) openLightbox(full, img?.alt || '');
    });
  });

  closeBtn?.addEventListener('click', closeLightbox);
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && lightbox.classList.contains('lightbox-open')) closeLightbox();
  });
</script>

<style>
  .page-hero { text-align: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
  .page-lede { max-width: 640px; margin: 1rem auto 0; font-size: 1rem; }

  .event-section { margin-top: 3.5rem; }
  .event-section:first-of-type { margin-top: 2rem; }

  .event-title {
    font-family: var(--font-serif);
    font-size: clamp(1.3rem, 2.5vw, 1.75rem);
    font-weight: 700;
    color: var(--dark);
    margin-bottom: 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--border);
  }

  .gallery-grid {
    display: grid;
    gap: 0.75rem;
  }

  .gallery-tile-btn {
    display: block;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .gallery-tile-btn img { display: block; transition: transform 0.25s ease; }
  .gallery-tile-btn:hover img { transform: scale(1.05); }
  .gallery-tile-btn:focus-visible { outline: 3px solid var(--teal); outline-offset: 2px; }

  .gallery-tile {
    aspect-ratio: 4 / 3;
    width: 100%;
    border-radius: var(--radius-md);
    object-fit: cover;
  }

  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.88);
    align-items: center;
    justify-content: center;
    padding: 2rem;
  }
  .lightbox.lightbox-open { display: flex; }
  .lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    width: 44px;
    height: 44px;
    font-size: 2rem;
    line-height: 1;
    color: var(--white);
    background: rgba(0, 0, 0, 0.4);
    border: none;
    border-radius: 50%;
    cursor: pointer;
  }
  .lightbox-close:hover { background: rgba(0, 0, 0, 0.7); }

  .gallery-placeholder {
    background: var(--teal-lt);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--teal);
  }

  @media (max-width: 720px) { .gallery-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .gallery-grid { grid-template-columns: 1fr; } }
</style>
