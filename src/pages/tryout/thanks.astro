---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="You're signed up!"
  description="Your free tryout session has been requested. We'll confirm by email within 1–2 business days."
>
  <section class="thanks">
    <div class="sec-inner thanks-inner">
      <h1 class="heading">You're all set!</h1>
      <p class="thanks-sub">
        Your free tryout request has been received. Check your inbox — a
        confirmation email is on its way. We'll follow up within 1–2 business
        days to lock in your spot.
      </p>
      <div class="reminder-box">
        <p class="reminder-title">Remember to bring:</p>
        <ul>
          <li>A helmet (inline, bicycle, or hockey)</li>
          <li>Gloves</li>
          <li>Knee and elbow pads (strongly recommended)</li>
        </ul>
        <p class="reminder-note">Rental skates will be ready for you if you requested them.</p>
      </div>
      <div class="thanks-actions">
        <a href="/" class="btn-primary">Back home</a>
        <a href="/programs" class="btn-outline">Learn about programs</a>
      </div>
      <p class="thanks-note">
        Questions? Email us at
        <a href="mailto:admin@letsskate.org">admin@letsskate.org</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .thanks {
    background: linear-gradient(180deg, var(--teal-xlt), var(--white));
    padding: 6rem 2.5rem;
  }
  .thanks-inner {
    text-align: center;
    max-width: 640px;
    margin: 0 auto;
  }
  .thanks-icon { font-size: 4rem; margin-bottom: 1rem; }
  .thanks-sub {
    font-size: 1.05rem;
    color: var(--mid);
    margin: 1rem auto 2rem;
    line-height: 1.85;
    max-width: 540px;
  }
  .reminder-box {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem 2rem;
    text-align: left;
    margin-bottom: 2rem;
  }
  .reminder-title {
    font-weight: 700;
    font-size: 0.9rem;
    color: var(--dark);
    margin-bottom: 0.6rem;
  }
  .reminder-box ul {
    list-style: disc;
    padding-left: 1.2rem;
    font-size: 0.9rem;
    color: var(--mid);
    line-height: 1.9;
    margin-bottom: 0.75rem;
  }
  .reminder-note {
    font-size: 0.82rem;
    color: var(--mid);
    font-style: italic;
  }
  .thanks-actions {
    display: flex;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .thanks-note {
    font-size: 0.88rem;
    color: var(--mid);
  }
  .thanks-note a { color: var(--teal); font-weight: 700; }
</style>
