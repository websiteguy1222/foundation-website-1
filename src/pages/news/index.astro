---
import BaseLayout from '../../layouts/BaseLayout.astro';

const press = [
  {
    title: "Olympic Speedskaters Visit Brookfield Elementary",
    date: "March 27, 2026",
    source: "Elmbrook Schools",
    summary: "Olympic speedskaters visited Brookfield Elementary to share their experiences and inspire the next generation of skaters in the Elmbrook community.",
    url: "https://www.elmbrookschools.org/news-details/~board/district-news/post/olympic-speedskaters-visit-brookfield-elementary",
  },
  {
    title: "The Elmbrook School District Speedskating Club National Qualifier - Jeremy D.",
    date: "March 24, 2026",
    source: "Elmbrook Schools",
    summary: "Jeremy Dong, a student-speedskater at Burleigh Elementary, qualified for the National Speedskating Championships, showcasing the success of the Foundation's speedskating program.",
    url: "https://burleigh.elmbrookschools.org/news-details/~board/burleigh-news/post/the-elmbrook-school-district-speedskating-club"
  },
  {
    title: "Elmbrook Education Foundation receives $2K donation from Let's Skate Foundation",
    date: "January 28th, 2026",
    source: "Waukesha Freeman",
    summary: "Let's Skate Foundation donated $2,000 to the Elmbrook Education Foundation, supporting the school district community that made everything possible.",
    url: "https://www.gmtoday.com/the_freeman/news/elmbrook-education-foundation-receives-2k-donation-from-let-s-skate-foundation/article_fb5888db-baf7-5463-ac05-08eb16fcb76c.html",
  },
  /*{
    title: "BC Student Named to Junior National Speedskating Team",
    date: "May 21, 2025",
    source: "Elmbrook Schools",
    summary: "Brookfield Central student Aidan Liu was named to the U.S. Junior National Speedskating Team, representing Team USA and the Elmbrook community on the international stage.",
    url: "https://www.elmbrookschools.org/news-details/~board/district-news/post/bc-student-named-to-junior-national-speedskating-team",
  },*/
  {
    title: "Mikey's Minute: Elmbrook Speedskating",
    date: "October 6th, 2025",
    source: "Elmbrook Schools",
    summary: "Mikey visits the Petit National Ice Center to learn more about the Elmbrook Speedskating Club from its founder Aidan Liu and its coaches to learn more about the Elmbrook Speedskating Club & the Let's Skate Foundation. He also interviews Olympic Gold Medalist Erin Jackson!",
    url: "https://www.youtube.com/watch?v=QYBw_uCIUSc",
  },
  {
    title: "Interscholastic Speedskating Challenge looks to put skating back in schools",
    date: "July 29, 2025",
    source: "US Speedskating",
    summary: "Let's Skate Foundation holds first Interscholastic Speedskating competition in over 45 years, aiming to revive a strong tradition and inspire a new generation of skaters",
    url: "https://www.usspeedskating.org/news/2025/july/29/interscholastic-speedskating-challenge-looks-to-put-skating-back-in-schools"
  },
  {
    title: "Brookfield teen's speed skating foundation finalist in statewide competition",
    date: "March 14, 2025",
    source: "FOX6 Milwaukee",
    summary: "Aidan Liu, a three-time national age-group champion and member of the 2025 U.S. Junior World Championships team, was named a finalist in Junior Achievement's Young Entrepreneur competition for his work founding Let's Skate Foundation.",
    url: "https://www.fox6now.com/news/brookfield-teens-speed-skating-foundation-finalist-in-statewide-competition",
  }, 
  {
    title: "Bold, consistent, and persistent: 16-year-old Aaron Liu is growing the sport",
    date: "August 31, 2021",
    source: "US Speedskating",
    summary: "Aaron Liu, a 16-year-old speedskater from Brookfield, Wisconsin, is making waves in the speedskating world with his bold vision, consistent dedication, and persistent efforts to grow the sport, including founding Let's Skate Foundation to provide access and opportunities for youth in speedskating.",
    url: "https://www.usspeedskating.org/news/featured-news/2021/august/31/bold-consistent-and-persistent-16-year-old-aaron-liu-is-growing-the-sport"
  },
];
---
<BaseLayout title="News" description="Updates, stories, and announcements from Let's Skate Foundation and Elmbrook Speedskating.">
  <section class="section">
    <div class="sec-inner page-hero">
      <h1 class="heading">News</h1>
    </div>

    <div class="sec-inner press-grid">
      {press.map((item) => (
        <a class="press-card" href={item.url} target="_blank" rel="noopener">
          <div class="press-meta">
            <span class="press-source">{item.source}</span>
            <span class="press-date">{item.date}</span>
          </div>
          <h2 class="press-title">{item.title}</h2>
          <p class="press-summary">{item.summary}</p>
          <span class="press-link">Read article →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { text-align: center; }
  .page-hero .label { justify-content: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
  .page-lede { max-width: 640px; margin: 1rem auto 0; font-size: 1rem; }

  .press-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2rem;
  }
  .press-card {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    text-decoration: none;
    transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
  }
  .press-card:hover {
    transform: translateY(-4px);
    border-color: var(--teal);
    box-shadow: 0 16px 40px rgba(0,119,139,0.08);
  }
  .press-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .press-source { color: var(--teal); }
  .press-date { color: var(--mid); }
  .press-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--dark);
    line-height: 1.4;
  }
  .press-summary {
    font-size: 0.87rem;
    color: var(--mid);
    line-height: 1.7;
    flex: 1;
  }
  .press-link {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--teal);
    margin-top: 0.25rem;
  }

  @media (max-width: 880px) { .press-grid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 520px) { .press-grid { grid-template-columns: 1fr; } }
</style>
