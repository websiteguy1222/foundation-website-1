---
import BaseLayout from '../layouts/BaseLayout.astro';

/* -----------------------------------------------------------------------
   Stripe Payment Links
   -----------------------------------------------------------------------
   Replace each placeholder URL with the real Payment Link you create in
   the Stripe dashboard. For each link, configure:
     - Collect customer's address → Billing address: REQUIRED
     - Metadata: org=lsf, kind=donation, amount_tier=<tier>
     - Success URL: https://letsskate.org/donate/thanks
   The first three are fixed-price one-time. The fourth is a "Customer
   chooses price" one-time link. The fifth is a recurring (monthly) link.
   ----------------------------------------------------------------------- */
const tiers = [
  {
    amount: '$25',
    label: 'Ice time for one practice',
    impact: 'Covers one skater for one practice session.',
    url: 'https://buy.stripe.com/REPLACE_ME_25',
    metadata: 'amount_tier=25',
  },
  {
    amount: '$50',
    label: 'A month of skating',
    impact: 'Covers one kid for a full month of practices.',
    url: 'https://buy.stripe.com/REPLACE_ME_50',
    metadata: 'amount_tier=50',
    featured: true,
  },
  {
    amount: '$100',
    label: 'New equipment',
    impact: 'Outfits a new skater with rental gear for the season.',
    url: 'https://buy.stripe.com/REPLACE_ME_100',
    metadata: 'amount_tier=100',
  },
];

const customUrl = 'https://buy.stripe.com/REPLACE_ME_CUSTOM';
const monthlyUrl = 'https://buy.stripe.com/REPLACE_ME_MONTHLY';
---
<BaseLayout
  title="Donate"
  description="Support youth speed skating in Wisconsin. Let's Skate Foundation is a 501(c)(3) nonprofit. EIN: 99-4111339. All donations are tax-deductible."
>
  <section class="donate-hero">
    <div class="sec-inner">
      <div class="label">
        <span class="label-dot" aria-hidden="true"></span>
        Support our mission
      </div>
      <h1 class="donate-h1">
        Your gift puts <em>more kids on the ice</em>
      </h1>
      <p class="donate-sub">
        Let's Skate Foundation funds ice time, equipment rentals, and the
        free-trial program that introduces new kids to speed skating —
        regardless of their family's ability to pay. Every donation goes
        straight to making the sport more accessible.
      </p>
    </div>
  </section>

  <section class="section donate-tiers">
    <div class="sec-inner">
      <h2 class="visually-hidden">Choose a donation amount</h2>
      <div class="tier-grid">
        {tiers.map((tier) => (
          <a
            href={tier.url}
            class={`tier-card${tier.featured ? ' is-featured' : ''}`}
            rel="noopener"
            aria-label={`Donate ${tier.amount} — ${tier.label}`}
          >
            {tier.featured && <span class="tier-badge">Most chosen</span>}
            <div class="tier-amount">{tier.amount}</div>
            <div class="tier-label">{tier.label}</div>
            <p class="tier-impact">{tier.impact}</p>
            <span class="tier-cta">Donate {tier.amount} →</span>
          </a>
        ))}
      </div>

      <div class="tier-secondary">
        <a href={customUrl} class="tier-flat" rel="noopener" aria-label="Donate a custom one-time amount">
          <div class="tier-flat-icon" aria-hidden="true">✨</div>
          <div>
            <div class="tier-flat-title">Choose your amount</div>
            <p class="tier-flat-desc">
              Give any amount, one time. You'll enter your gift on the next page.
            </p>
          </div>
          <span class="tier-flat-cta" aria-hidden="true">→</span>
        </a>
        <a href={monthlyUrl} class="tier-flat is-monthly" rel="noopener" aria-label="Donate monthly">
          <div class="tier-flat-icon" aria-hidden="true">🔁</div>
          <div>
            <div class="tier-flat-title">Give monthly</div>
            <p class="tier-flat-desc">
              Become a sustaining supporter — your gift keeps the ice
              cold and the kids on it, every month.
            </p>
          </div>
          <span class="tier-flat-cta" aria-hidden="true">→</span>
        </a>
      </div>

      <p class="tier-handoff">
        Donations are processed securely by Stripe.
        You'll be taken to a Stripe-hosted checkout to complete your gift.
      </p>
    </div>
  </section>

  <section class="section donate-why">
    <div class="sec-inner why-grid">
      <div>
        <div class="label">
          <span class="label-dot" aria-hidden="true"></span>
          Where your gift goes
        </div>
        <h2 class="heading">Every dollar puts <em>more kids on the ice</em></h2>
        <p class="body-text">
          We've taught over 300 kids how to skate and elevated 10 to the
          national level — all through a partnership model that costs
          families almost nothing. Your donation funds:
        </p>
        <ul class="why-list">
          <li><strong>Ice time</strong> at the Pettit National Ice Center</li>
          <li><strong>Equipment rentals</strong> so new skaters can try the sport without a five-figure gear investment</li>
          <li><strong>The free-trial program</strong> that gets every kid two practices on us</li>
          <li><strong>Travel and competition support</strong> for skaters who reach the national level</li>
        </ul>
      </div>
      <aside class="why-card">
        <div class="why-stat">
          <span class="why-stat-num">300+</span>
          <span class="why-stat-lbl">kids taught to skate</span>
        </div>
        <div class="why-stat">
          <span class="why-stat-num">10</span>
          <span class="why-stat-lbl">skaters at the national level</span>
        </div>
        <div class="why-stat">
          <span class="why-stat-num">4 yrs</span>
          <span class="why-stat-lbl">of partnership with Elmbrook</span>
        </div>
        <div class="why-stat">
          <span class="why-stat-num">1</span>
          <span class="why-stat-lbl">school-district club in the nation</span>
        </div>
      </aside>
    </div>
  </section>

  <section class="section donate-trust">
    <div class="sec-inner trust-inner">
      <div class="trust-card">
        <div class="trust-card-icon" aria-hidden="true">📜</div>
        <h3 class="trust-card-title">Tax-deductible</h3>
        <p class="trust-card-body">
          Let's Skate Foundation is a 501(c)(3) tax-exempt organization.
          <strong>EIN: 99-4111339.</strong> Your gift is deductible to
          the fullest extent allowed by law. You'll receive an emailed
          receipt that doubles as your IRS acknowledgment.
        </p>
      </div>
      <div class="trust-card">
        <div class="trust-card-icon" aria-hidden="true">🔒</div>
        <h3 class="trust-card-title">Secure &amp; private</h3>
        <p class="trust-card-body">
          Payments are processed by Stripe. We never see or store your card
          information. Your name and mailing address are kept only as long
          as needed for year-end donor records. See our
          <a href="/privacy">privacy policy</a> for details.
        </p>
      </div>
      <div class="trust-card">
        <div class="trust-card-icon" aria-hidden="true">🤝</div>
        <h3 class="trust-card-title">Other ways to give</h3>
        <p class="trust-card-body">
          Donor-advised funds, stock gifts, matching gifts, or in-kind
          contributions? Email
          <a href="mailto:admin@letsskate.org">admin@letsskate.org</a>
          and we'll work with you.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .visually-hidden {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  .donate-hero {
    background: linear-gradient(180deg, var(--teal-xlt) 0%, var(--white) 100%);
    padding: 4rem 2.5rem 2rem;
    text-align: center;
  }
  .donate-h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4.5vw, 3.6rem);
    line-height: 1.1;
    max-width: 720px;
    margin: 0 auto 1rem;
  }
  .donate-h1 em { font-style: italic; color: var(--teal); }
  .donate-sub {
    max-width: 640px;
    margin: 0 auto;
    font-size: 1.05rem;
    color: var(--mid);
    line-height: 1.85;
  }
  .donate-hero .label { justify-content: center; margin-bottom: 1rem; }

  .donate-tiers { background: var(--off); padding-top: 3rem; }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .tier-card {
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem 1.75rem;
    text-decoration: none;
    color: var(--dark);
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    display: flex; flex-direction: column;
  }
  .tier-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(0,119,139,0.1);
    border-color: var(--teal);
  }
  .tier-card.is-featured {
    border-color: var(--teal);
    background: var(--teal);
    color: #fff;
  }
  .tier-card.is-featured:hover {
    background: var(--teal-dk);
    border-color: var(--teal-dk);
  }
  .tier-badge {
    position: absolute; top: -10px; right: 1.5rem;
    background: var(--pink); color: var(--dark);
    font-size: 0.7rem; font-weight: 800;
    letter-spacing: 0.5px; text-transform: uppercase;
    padding: 4px 12px; border-radius: var(--radius-pill);
  }
  .tier-amount {
    font-family: var(--font-serif);
    font-size: 2.8rem; font-weight: 700;
    line-height: 1; margin-bottom: 0.25rem;
  }
  .tier-label {
    font-size: 0.95rem; font-weight: 700;
    margin-bottom: 0.5rem;
  }
  .tier-impact {
    font-size: 0.85rem;
    color: var(--mid);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1.25rem;
  }
  .tier-card.is-featured .tier-impact { color: rgba(255,255,255,0.85); }
  .tier-cta {
    font-size: 0.85rem; font-weight: 800;
    color: var(--teal);
  }
  .tier-card.is-featured .tier-cta { color: #fff; }

  .tier-secondary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 1rem;
  }
  .tier-flat {
    background: var(--white);
    border: 2px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 1rem;
    align-items: center;
    text-decoration: none;
    color: var(--dark);
    transition: transform 0.2s, border-color 0.2s;
  }
  .tier-flat:hover {
    transform: translateY(-2px);
    border-color: var(--teal);
  }
  .tier-flat.is-monthly { background: var(--green-lt); border-color: var(--green); }
  .tier-flat.is-monthly:hover { border-color: var(--green-dk); }
  .tier-flat-icon { font-size: 1.6rem; }
  .tier-flat-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .tier-flat-desc {
    font-size: 0.85rem;
    color: var(--mid);
    line-height: 1.55;
  }
  .tier-flat-cta {
    font-size: 1.4rem;
    color: var(--teal);
    font-weight: 700;
  }

  .tier-handoff {
    text-align: center;
    font-size: 0.85rem;
    color: var(--mid);
    margin-top: 2rem;
  }

  .donate-why { background: var(--white); }
  .why-grid {
    display: grid; grid-template-columns: 1.4fr 1fr;
    gap: 4rem; align-items: start;
  }
  .why-list {
    list-style: none;
    margin-top: 1rem;
  }
  .why-list li {
    padding: 0.75rem 0 0.75rem 1.75rem;
    border-bottom: 1px solid var(--border);
    position: relative;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--mid);
  }
  .why-list li::before {
    content: '✓';
    position: absolute; left: 0; top: 0.75rem;
    color: var(--teal); font-weight: 800;
  }
  .why-list li strong { color: var(--dark); }

  .why-card {
    background: var(--teal);
    border-radius: var(--radius-xl);
    padding: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }
  .why-stat { display: flex; flex-direction: column; }
  .why-stat-num {
    font-family: var(--font-serif);
    font-size: 2.4rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }
  .why-stat-lbl {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.85);
    margin-top: 0.5rem;
    line-height: 1.45;
  }

  .donate-trust { background: var(--off); }
  .trust-inner {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  .trust-card {
    background: var(--white);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    border: 1px solid var(--border);
  }
  .trust-card-icon { font-size: 1.6rem; margin-bottom: 0.75rem; }
  .trust-card-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .trust-card-body {
    font-size: 0.88rem;
    color: var(--mid);
    line-height: 1.7;
  }
  .trust-card-body a { color: var(--teal); font-weight: 700; }

  @media (max-width: 880px) {
    .tier-grid { grid-template-columns: 1fr; }
    .tier-secondary { grid-template-columns: 1fr; }
    .why-grid { grid-template-columns: 1fr; gap: 2rem; }
    .trust-inner { grid-template-columns: 1fr; }
    .why-card { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 480px) {
    .why-card { grid-template-columns: 1fr; }
  }
</style>
