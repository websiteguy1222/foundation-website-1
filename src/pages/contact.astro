---
import BaseLayout from '../layouts/BaseLayout.astro';

// To wire up form submissions, create a free Formspree project at
// https://formspree.io and replace the action URL below with your endpoint
// (looks like https://formspree.io/f/YOUR_FORM_ID). Until then the form
// submits to the placeholder and won't actually deliver.
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/mdajzpoy';
---
<BaseLayout title="Contact" description="Get in touch with Let's Skate Foundation. Email admin@letsskate.org or use the form.">
  <section class="section">
    <div class="sec-inner page-hero">
      <h1 class="heading">Contact us</h1>
      <p class="body-text page-lede">
        Questions, ideas, sponsorships, or just want to say hi?
        Email us at
        <a href="mailto:admin@letsskate.org">admin@letsskate.org</a>
        or use the form below.
      </p>
    </div>

    <div class="sec-inner contact-grid">
      <form
        class="contact-form"
        action={FORMSPREE_ENDPOINT}
        method="POST"
      >
        <label>
          <span>Your name</span>
          <input type="text" name="name" required />
        </label>
        <label>
          <span>Email</span>
          <input type="email" name="email" required />
        </label>
        <label>
          <span>Message</span>
          <textarea name="message" rows="5" required></textarea>
        </label>
        <button type="submit" class="btn-primary">Send message</button>
        <p class="form-hint">We typically reply within a couple of days.</p>
      </form>

      <aside class="contact-aside">
        <h2 class="heading-sm">Other ways to reach us</h2>
        <p class="body-text">
          📍 <strong>Practice location:</strong><br />
          Pettit National Ice Center        </p>
        <p class="body-text">
          📧 <strong>Email:</strong><br />
          <a href="mailto:admin@letsskate.org">admin@letsskate.org</a>
        </p>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero { text-align: center; }
  .page-hero .label { justify-content: center; }
  .page-hero h1.heading { font-size: clamp(2.2rem, 4vw, 3rem); }
  .page-lede { max-width: 640px; margin: 1rem auto 0; font-size: 1rem; }
  .page-lede a { color: var(--teal); font-weight: 700; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 3rem;
    margin-top: 2rem;
  }

  .contact-form { display: flex; flex-direction: column; gap: 1rem; }
  .contact-form label {
    display: flex; flex-direction: column;
    font-size: 0.85rem; font-weight: 700;
    color: var(--mid); gap: 6px;
  }
  .contact-form input,
  .contact-form textarea {
    font: inherit;
    font-size: 0.95rem;
    padding: 12px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--white);
    color: var(--dark);
  }
  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    border-color: var(--teal);
    box-shadow: 0 0 0 3px rgba(0,119,139,0.15);
  }
  .form-hint { font-size: 0.78rem; color: var(--mid); font-weight: 500; }

  .contact-aside {
    background: var(--off);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }
  .contact-aside p { margin-top: 1rem; font-size: 0.92rem; }
  .contact-aside a { color: var(--teal); font-weight: 700; }
  .heading-sm {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0;
    color: var(--dark);
  }

  @media (max-width: 720px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
  }
</style>
